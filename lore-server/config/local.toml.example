# =============================================================================
# Lore Server Local Development Configuration
# =============================================================================
# This example shows the correct configuration formats:
# - Local stores use predefined type format: [immutable_store.local], [mutable_store.local]
# - Fixed topology uses predefined type format: [topology.fixed]
# - AWS stores use plugin format: [plugins.aws]
# - Consul topology uses plugin format: [plugins.consul]

[server.quic.certificate]
cert_file = "./cert.pem"
pkey_file = "./key.pem"

[server.quic_internal]
# the certs being generated locally aren't compatible with WebPkiClientVerifier
# because it is strict about the CA constraint
verify_client_certs = false

[server.quic_internal.certificate]
cert_file = "./cert.pem"
pkey_file = "./key.pem"

# Use `openssl rand -hex 32` to generate a key
[server.http]
presigned_url_hmac_key = "<INSERT 32 BYTE HEX ENCODED KEY HERE>"

# =============================================================================
# Store Configuration
# =============================================================================

# Immutable Store - Local filesystem
[immutable_store]
mode = "local"

# Mutable Store - Local filesystem
[mutable_store]
mode = "local"

# Lock Store - Local in-memory (optional)
[lock_store]
mode = "local"

# =============================================================================
# Local Store Configuration
# =============================================================================

# Local immutable store settings
[immutable_store.local]
path = "/tmp/urc-store"
flush_delay_seconds = 10

# Local mutable store settings
[mutable_store.local]
path = "/tmp/urc-store"
flush_delay_seconds = 10

# =============================================================================
# AWS Store Plugin Configuration (For composite or AWS-only mode)
# =============================================================================
# Uncomment and configure if using AWS stores
#
# [plugins.aws]
# # HTTP client settings (shared)
# http.timeout_millis = 5000
#
# # Immutable store (S3 + DynamoDB)
# immutable_store.s3_bucket = "urc-immutable-store-local"
# immutable_store.s3_endpoint_url = "http://127.0.0.1:9000"
# immutable_store.s3_slow_operation_threshold_millis = 2000
# immutable_store.dynamodb_endpoint_url = "http://127.0.0.1:9090"
# immutable_store.dynamodb_fragments_table = "urc-fragments-local"
# immutable_store.dynamodb_metadata_table = "urc-fragment-metadata-local"
# immutable_store.dynamodb_slow_operation_threshold_millis = 500
#
# # Mutable store (DynamoDB)
# mutable_store.dynamodb_table = "urc-mutable-store-local"
# mutable_store.dynamodb_endpoint_url = "http://127.0.0.1:9090"
# mutable_store.dynamodb_slow_operation_threshold_millis = 500

# DynamoDB lock store plugin (for AWS locks)
# lock_store.dynamodb_table_name = "urc-locks-local"
# lock_store.dynamodb_endpoint_url = "http://127.0.0.1:9090"
# lock_store.dynamodb_slow_operation_threshold_millis = 1000

# =============================================================================
# Composite Store Configuration
# =============================================================================
# Uncomment below for composite store mode with local cache + AWS durable tier

# [immutable_store]
# mode = "composite"
#
# [immutable_store.composite.local]
# mode = "local"
# local.path = "/tmp/urc-cache"
# local.flush_delay_seconds = 10
# local.max_capacity = 100000
# local.max_size = 5368709120  # 5GB
#
# [immutable_store.composite.durable]
# Configuration in plugins.aws section
# mode = "aws"

# =============================================================================
# Topology Configuration
# =============================================================================

# No topology for local development (single-node mode)
[topology]
provider = "none"

# For fixed topology (testing) - uses predefined type format:
# [topology]
# provider = "fixed"
#
# [topology.fixed]
# peers = [{ address = "localhost", port = 41337, locality = "SameRegion" }]

# For Consul (production) - uses plugin format:
# [topology]
# provider = "consul"
#
# [plugins.consul]
# address = "http://localhost:8500"
# service_name = "urc-server"

# =============================================================================
# Telemetry Configuration
# =============================================================================

[telemetry.logger]
format = "ansi"

# =============================================================================
# Notification Configuration
# =============================================================================

[notification]
mode = "local"
